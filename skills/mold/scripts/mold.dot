digraph mold_gates {
  rankdir=LR;
  node [shape=box];
  explore [label="Explore", kind="mode"];
  ground [label="Ground", kind="mode"];
  shape [label="Shape", kind="mode"];
  sketch [label="Sketch", kind="mode"];
  grill [label="Grill", kind="mode"];
  diagnose [label="Diagnose", kind="mode"];
  problem_statement [label="Problem statement: grounded, agreed", kind="gate"];
  at_least_2_options_weighed_do_nothing_included [label="At least 2 options weighed (Do Nothing included)", kind="gate"];
  chosen_option_grounded_in_codebase_evidence [label="Chosen option grounded in codebase evidence", kind="gate"];
  interface_sketches [label="Interface sketches: every public seam has a pseudocode signature", kind="gate"];
  cross_module_calls_go_through_public_interfaces_not_internals [label="Cross-module calls go through public interfaces, not internals", kind="gate"];
  identity_nouns [label="Identity nouns: each bound to a code referent or marked NEW ENTITY (an ALIAS must be resolved, not just noted)", kind="gate"];
  non_goals_audit [label="Non-goals audit: every bullet traces to a user-stated out-of-scope item or is marked [AGENT-INTRODUCED]", kind="gate"];
  validate_cycles [label="Validate cycles: all launched cycles judged", kind="gate"];
  chosen_option_grilled_1_stress_test_entry_per_major_branch [label="Chosen option Grilled (≥1 stress-test entry per major branch)", kind="gate"];
  open_questions_all_marked_tbd_blocked_none_silent [label="Open questions all marked [TBD] / [BLOCKED] / [?] (none silent)", kind="gate"];
  quality_gates_specified_1_runnable_command [label="Quality gates specified (≥1 runnable command)", kind="gate"];
  reproduction_loop_captured_if_diagnose_ran_or_blocked_if_no_loop_is_possible [label="Reproduction loop captured if Diagnose ran (or [BLOCKED] if no loop is possible)", kind="gate"];
  handshake [label="Two-key handshake", kind="handshake"];
  curdle [label="Curdle (extract spec)", kind="terminal"];
  explore -> ground;
  ground -> shape;
  shape -> sketch;
  sketch -> grill;
  diagnose -> shape;
  problem_statement -> handshake;
  at_least_2_options_weighed_do_nothing_included -> handshake;
  chosen_option_grounded_in_codebase_evidence -> handshake;
  interface_sketches -> handshake;
  cross_module_calls_go_through_public_interfaces_not_internals -> handshake;
  identity_nouns -> handshake;
  non_goals_audit -> handshake;
  validate_cycles -> handshake;
  chosen_option_grilled_1_stress_test_entry_per_major_branch -> handshake;
  open_questions_all_marked_tbd_blocked_none_silent -> handshake;
  quality_gates_specified_1_runnable_command -> handshake;
  reproduction_loop_captured_if_diagnose_ran_or_blocked_if_no_loop_is_possible -> handshake;
  grill -> handshake;
  handshake -> curdle [label="both keys"];
}
